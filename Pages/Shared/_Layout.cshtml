<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - ArtNest</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

<header class="site-header">
    <nav class="site-nav">

        <a class="logo-block" href="/">
            <span class="logo-title">ARTNEST</span>
            <span class="logo-subtitle">Personal Museum Memory</span>
        </a>

        <div class="nav-links">
            <a href="/Explore">Explore</a>
            <a href="/Wishlist">Wishlist</a>
            <a href="/Journal">Journal</a>
        </div>

        <div class="nav-actions">
            <a class="btn-login" href="/Login">Log In</a>
            <a class="btn-signup" href="/Register">Sign Up</a>
        </div>

    </nav>
</header>

<main>
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="site-footer-inner">
        <a class="footer-logo" href="/">ARTNEST</a>
        <div class="footer-links">
            <a href="#">About</a>
            <a href="#">Contact</a>
            <a href="#">Privacy</a>
            <a href="#">Terms</a>
        </div>
    </div>
</footer>

</body>
</html>